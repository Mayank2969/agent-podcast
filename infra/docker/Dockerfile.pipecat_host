FROM python:3.11-slim

WORKDIR /app

# Install Python dependencies
COPY pipecat_host/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY backend/ /app/backend/
COPY pipecat_host/ /app/pipecat_host/

ENV PYTHONPATH=/app

CMD ["python", "-m", "pipecat_host"]
