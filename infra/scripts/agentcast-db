#!/usr/bin/env bash
# agentcast-db — Lightning-fast production DB access via SSM tunnel
#
# Usage:
#   agentcast-db                         # Interactive psql shell
#   agentcast-db "SELECT * FROM ..."     # Run a single query
#   agentcast-db interview <id>          # Show interview state
#   agentcast-db interviews [limit]      # List recent interviews
#   agentcast-db stuck                   # Show orphaned IN_PROGRESS sessions
#   agentcast-db clear-stuck             # Mark all stuck sessions as FAILED
#
# Requirements: aws, session-manager-plugin, psql
# ------------------------------------------------------------------
set -euo pipefail

INSTANCE_ID="i-00751b708bfa449e9"
REGION="us-east-1"
DB_HOST="agentcast-db.coru6m0i6fj8.us-east-1.rds.amazonaws.com"
DB_USER="agentcast"
DB_NAME="agentcast"
DB_PASS="agent_456_cast_343"
LOCAL_PORT="15432"

# ── Find psql ──────────────────────────────────────────────────────
PSQL_BIN=""
for candidate in \
    "$(command -v psql 2>/dev/null)" \
    "/opt/homebrew/opt/postgresql@18/bin/psql" \
    "/opt/homebrew/opt/postgresql@17/bin/psql" \
    "/opt/homebrew/opt/libpq/bin/psql" \
    "/usr/local/bin/psql"; do
    if [ -x "$candidate" ]; then PSQL_BIN="$candidate"; break; fi
done
if [ -z "$PSQL_BIN" ]; then
    echo "Error: psql not found. Install via: brew install postgresql@18" >&2
    exit 1
fi

# ── Colors ─────────────────────────────────────────────────────────
BOLD='\033[1m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; RESET='\033[0m'

_info()  { echo -e "${CYAN}▸  $*${RESET}"; }
_ok()    { echo -e "${GREEN}✓  $*${RESET}"; }
_warn()  { echo -e "${YELLOW}⚠  $*${RESET}"; }
_err()   { echo -e "${RED}✗  $*${RESET}" >&2; }

# ── Tunnel Management ──────────────────────────────────────────────
_tunnel_pid=""
_start_tunnel() {
    _info "Opening SSM port-forward tunnel → RDS:5432 on localhost:${LOCAL_PORT}…"
    aws ssm start-session \
        --target "$INSTANCE_ID" \
        --region "$REGION" \
        --document-name AWS-StartPortForwardingSessionToRemoteHost \
        --parameters "{\"host\":[\"${DB_HOST}\"],\"portNumber\":[\"5432\"],\"localPortNumber\":[\"${LOCAL_PORT}\"]}" \
        > /dev/null 2>&1 &
    _tunnel_pid=$!

    # Wait for the tunnel to be ready (max 10s)
    local attempts=0
    while ! nc -z 127.0.0.1 "$LOCAL_PORT" 2>/dev/null; do
        sleep 0.5
        attempts=$((attempts + 1))
        if [ $attempts -ge 20 ]; then
            _err "Tunnel did not open in 10s. Check SSM connectivity."
            kill "$_tunnel_pid" 2>/dev/null; exit 1
        fi
    done
    _ok "Tunnel ready on localhost:${LOCAL_PORT} (pid ${_tunnel_pid})"
}

_stop_tunnel() {
    if [ -n "$_tunnel_pid" ]; then
        kill "$_tunnel_pid" 2>/dev/null && _info "Tunnel closed." || true
    fi
}

trap _stop_tunnel EXIT INT TERM

# ── DB Query Helper ────────────────────────────────────────────────
_psql() {
    PGPASSWORD="$DB_PASS" "$PSQL_BIN" \
        -h 127.0.0.1 -p "$LOCAL_PORT" \
        -U "$DB_USER" -d "$DB_NAME" \
        "$@"
}

# ── Commands ───────────────────────────────────────────────────────
cmd_interview() {
    local id="${1:-}"
    if [ -z "$id" ]; then _err "Usage: agentcast-db interview <id>"; exit 1; fi
    _psql -c "
        SELECT
            interview_id,
            agent_id,
            status,
            topic,
            created_at AT TIME ZONE 'UTC' AS created_at_utc,
            updated_at AT TIME ZONE 'UTC' AS updated_at_utc,
            completed_at AT TIME ZONE 'UTC' AS completed_at_utc,
            (SELECT count(*) FROM interview_messages WHERE interview_id = i.interview_id) AS msg_count
        FROM interviews i
        WHERE interview_id::text LIKE '%${id}%';
    "
}

cmd_interviews() {
    local limit="${1:-10}"
    _psql -c "
        SELECT
            interview_id,
            agent_id,
            status,
            COALESCE(topic, 'General') AS topic,
            created_at AT TIME ZONE 'UTC' AS created_utc
        FROM interviews
        ORDER BY created_at DESC
        LIMIT ${limit};
    "
}

cmd_stuck() {
    _psql -c "
        SELECT
            interview_id,
            agent_id,
            status,
            updated_at AT TIME ZONE 'UTC' AS last_updated,
            EXTRACT(EPOCH FROM (NOW() - updated_at)) / 60 AS stuck_minutes
        FROM interviews
        WHERE status IN ('IN_PROGRESS', 'QUEUED')
        ORDER BY updated_at ASC;
    "
}

cmd_clear_stuck() {
    _warn "This will mark ALL IN_PROGRESS and stale QUEUED interviews as FAILED."
    read -r -p "Are you sure? (y/N) " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo "Aborted."; exit 0
    fi
    _psql -c "
        UPDATE interviews
        SET status = 'FAILED', completed_at = NOW()
        WHERE status = 'IN_PROGRESS'
           OR (status = 'QUEUED' AND created_at < NOW() - INTERVAL '10 minutes')
        RETURNING interview_id, agent_id, status;
    "
    _ok "Done."
}

# ── Main Dispatch ──────────────────────────────────────────────────
CMD="${1:-}"

_start_tunnel

case "$CMD" in
    interview)    cmd_interview "${2:-}" ;;
    interviews)   cmd_interviews "${2:-10}" ;;
    stuck)        cmd_stuck ;;
    clear-stuck)  cmd_clear_stuck ;;
    "")           _psql ;;   # interactive shell
    *)
        # Raw SQL query
        _psql -c "$CMD"
        ;;
esac
