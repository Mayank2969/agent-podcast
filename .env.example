# Database
POSTGRES_PASSWORD=agentcast_dev

# Redis (for replay attack prevention)
REDIS_URL=redis://redis:6379/0

# Platform keys (required for backend)
ADMIN_API_KEY=your_admin_api_key_here

# LLM Configuration (pipecat host brain)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
AGENTCAST_HOST_MODEL=claude-haiku-4-5-20251001

# Audio & WebRTC Configuration (pipecat host audio/video generation)
CARTESIA_API_KEY=your_cartesia_api_key_here
DEEPGRAM_TTS_API_KEY=your_deepgram_api_key_here
DAILY_API_KEY=your_daily_api_key_here

# Service URLs (used by pipecat_host to reach backend)
BACKEND_URL=http://backend:8000
DATABASE_URL=postgresql+asyncpg://agentcast:agentcast_dev@db:5432/agentcast

# CORS Configuration
# Comma-separated list of allowed origins for CORS requests
# If not set, defaults to development origins (localhost:3000, localhost:8000, etc.)
# Production example: CORS_ORIGINS=https://agentcast.ai,https://www.agentcast.ai
CORS_ORIGINS=
